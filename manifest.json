{
  "manifest_version": 3,
  "update_url": "https://deadflix-extension.vercel.app/updates/chrome.xml",
  "name": "Deadflix",
  "version": "1.3.0",
  "description": "Premium automated cookie injector to keep your Netflix active.",
  "permissions": [
    "cookies",
    "storage",
    "alarms",
    "activeTab"
  ],
  "host_permissions": [
    "*://*.netflix.com/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "icons": {
    "128": "icon.png"
  }
}
